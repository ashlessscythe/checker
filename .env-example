# rename this to .env.local

# PRECHECK_TOKEN_SECRET="somethingsupersecret"
# NEXT_PUBLIC_INSTANT_APP_ID=somethingnice
# Prefer http://localhost:3000 for local dev (Turnstile). http://127.0.0.1:3000 is normalized to localhost in dev for server-built links only.
# NEXT_PUBLIC_APP_BASE_URL="http://localhost:3000"
# NEXT_PUBLIC_THRESHOLD_HOURS=14                # checkins older than this number of hours appear faded
# NEXT_PUBLIC_ENABLE_AUTO_CLEANUP=false         # enable auto checkout
# NEXT_PUBLIC_STALE_CHECKIN_CLEANUP_HOURS=18    # users with checked in for more than this number of hours will be checked out 
# NEXT_PUBLIC_CLEANUP_INTERVAL_MINUTES=20       # loop time for autocheckout
# NEXT_PUBLIC_DEBOUNCE_TIMEOUT=5000             # debounce timeout in milliseconds for double scan prevention
# NEXT_PUBLIC_AUTO_RELOAD_MINUTES=30
# RESEND_API_KEY="keygoeshere"
# RESEND_FROM_EMAIL="Checker <noreply@example.com>"
# company logo url
# NEXT_PUBLIC_COMPANY_LOGO_URL="https://example.com/logo.png"
# Visitor pre-check emails/PDF/admin "When" use this IANA timezone (default America/Denver).
# NEXT_PUBLIC_VISITOR_DISPLAY_TIMEZONE="America/Denver"
# TURNSTILE_SECRET_KEY="keygoeshere"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="keygoeshere"
# NEXT_PUBLIC_TURNSTILE_MODE="invisible"
# or: "interactive"